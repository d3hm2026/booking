# انسخ هذا الملف باسم .env.local وضع فيه قيمك الفعلية
# .env.local لن يُرفع أبداً على GitHub (محمي تلقائياً في .gitignore)

# Project URL من Supabase Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://rupwowwbghepnsayodok.supabase.co

# anon public key من Supabase Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=ضع_المفتاح_هنا

# service_role key من Supabase Settings → API
# ⚠️ سري جداً - لا تشاركه مع أي شخص ولا تضعه إلا هنا
SUPABASE_SERVICE_ROLE_KEY=ضع_المفتاح_السري_هنا

# رمز تشفير الجلسات (session) - أي نص عشوائي طويل تختاره بنفسك
# مثال لتوليد واحد: شغّل في الترمنال: openssl rand -base64 32
SESSION_SECRET=ضع_نص_عشوائي_طويل_هنا
